{
  "manifest_version": 3,
  "name": "Manga Tracker Companion",
  "version": "0.3.1",
  "description": "Sign in to Manga Tracker and your manga and manhwa reading progress syncs from any reader. Optional prompts, badge, and shortcuts.",
  "homepage_url": "https://github.com/somaqzz12/manhwa-manga-tracking-Through-out-different-websites",
  "permissions": ["storage", "activeTab", "tabs", "alarms", "contextMenus"],
  "host_permissions": [
    "<all_urls>",
    "https://manhwa-manga-tracking-through-out.onrender.com/*",
    "http://127.0.0.1:5000/*"
  ],
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "Manga Tracker",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "commands": {
    "track-current-chapter": {
      "suggested_key": {
        "default": "Alt+Shift+T",
        "windows": "Alt+Shift+T",
        "mac": "Alt+Shift+T",
        "linux": "Alt+Shift+T"
      },
      "description": "Track the current chapter page"
    }
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ]
}
